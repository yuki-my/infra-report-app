# このファイルをコピーして .env を作り、実際の値を入れてください。
#   cp .env.example .env
# .env 自体は .gitignore で除外されているのでGitHubには上がりません。

# セッション署名用の秘密鍵。以下のコマンドで生成できます:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ここに生成した値を貼り付けてください

# 自治体職員アカウントの初期パスワード（必ずデフォルトから変更すること）
SETAGAYA_STAFF_PASSWORD=変更してください
MIZUHO_STAFF_PASSWORD=変更してください

# 本番環境であることを明示する（SECRET_KEY未設定時に起動を止めるためのガード）
FLASK_ENV=production
